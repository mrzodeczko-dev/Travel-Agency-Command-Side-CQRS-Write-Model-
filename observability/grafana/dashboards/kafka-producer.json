{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "KafkaTemplate Send Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(spring_kafka_template_seconds_count[1m])",
          "legendFormat": "{{name}} {{result}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "KafkaTemplate Send Duration (avg / max)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(spring_kafka_template_seconds_sum[5m]) / rate(spring_kafka_template_seconds_count[5m])",
          "legendFormat": "avg {{name}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "spring_kafka_template_seconds_max",
          "legendFormat": "max {{name}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Outbox Publish Rate (by scheduler)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(outbox_events_published_total[1m])",
          "legendFormat": "published {{scheduler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "rate(outbox_events_failed_total[1m])",
          "legendFormat": "failed {{scheduler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Outbox Publish Duration (avg / max by scheduler)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(outbox_publish_duration_seconds_sum[5m]) / rate(outbox_publish_duration_seconds_count[5m])",
          "legendFormat": "avg {{scheduler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "outbox_publish_duration_seconds_max",
          "legendFormat": "max {{scheduler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Outbox Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "outbox_backlog",
          "legendFormat": "pending",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Dead Letter Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "outbox_dead_letter_backlog",
          "legendFormat": "dead letters",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Dead Lettered Events (rate)",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(outbox_events_dead_lettered_total[1m])",
          "legendFormat": "{{scheduler}}",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "spanNulls": true }
        },
        "overrides": []
      }
    },
    {
      "title": "Scheduled Task Execution Duration (outbox schedulers)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(tasks_scheduled_execution_seconds_sum[5m]) / rate(tasks_scheduled_execution_seconds_count[5m])",
          "legendFormat": "avg {{code_function}} ({{code_namespace}})",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "tasks_scheduled_execution_seconds_max",
          "legendFormat": "max {{code_function}} ({{code_namespace}})",
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["travel-agency", "kafka", "outbox"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Travel Agency Command side — Kafka & Outbox",
  "uid": "kafka-producer"
}
